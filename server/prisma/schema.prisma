generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                @id @default(cuid())
  username           String
  usernameNormalized String                @unique
  passwordHash       String
  avatarKey          String?
  tutorialCompleted  Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  sessions           Session[]
  statistic          UserStatistic?
  audioPreference    UserAudioPreference?
  achievementProgress AchievementProgress[]
  hostedLobbies       Lobby[]              @relation("LobbyHost")
  lobbyMemberships    LobbyPlayer[]
}

model UserAudioPreference {
  userId    String   @id
  master    Int      @default(72)
  music     Int      @default(34)
  ui        Int      @default(64)
  game      Int      @default(76)
  muted     Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum LobbyStatus {
  OPEN
  ACTIVE
  CLOSED
}

enum GameStatus {
  ACTIVE
  FINISHED
}

model Lobby {
  id                     String       @id @default(cuid())
  code                   String       @unique
  name                   String       @default("Neue Lobby")
  hostId                 String
  status                 LobbyStatus  @default(OPEN)
  maxPlayers             Int          @default(6)
  jokersPerPlayer        Int          @default(1)
  maxTurnSeconds         Int?
  streetsRequireSameSuit Boolean      @default(false)
  confirmTurnEnd         Boolean      @default(true)
  createdAt              DateTime     @default(now())
  expiresAt              DateTime?
  host                   User         @relation("LobbyHost", fields: [hostId], references: [id], onDelete: Restrict)
  players                LobbyPlayer[]
  game                   Game?
}

model LobbyPlayer {
  id       String   @id @default(cuid())
  lobbyId  String
  userId   String
  ready    Boolean  @default(false)
  joinedAt DateTime @default(now())
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
  @@unique([userId])
}

model Game {
  id        String     @id @default(cuid())
  lobbyId   String     @unique
  status    GameStatus @default(ACTIVE)
  phase     Int        @default(1)
  version   Int        @default(1)
  state     Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lobby     Lobby      @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  statisticsRollup GameStatisticsRollup?
}

model GameStatisticsRollup {
  gameId      String   @id
  processedAt DateTime @default(now())
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserStatistic {
  userId          String   @id
  gamesPlayed     Int      @default(0)
  gamesWon        Int      @default(0)
  podiumFinishes  Int      @default(0)
  totalPenalty    Int      @default(0)
  phasesLaid      Int      @default(0)
  meldsLaid       Int      @default(0)
  jokersPlayed    Int      @default(0)
  cardsBought     Int      @default(0)
  timeouts        Int      @default(0)
  reconnects      Int      @default(0)
  movesPlayed     Int      @default(0)
  coinPenalty     Int      @default(0)
  longestStreet   Int      @default(0)
  phaseWinsMask   Int      @default(0)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AchievementProgress {
  id          String   @id @default(cuid())
  userId      String
  achievement String
  progress    Int      @default(0)
  unlockedAt  DateTime?
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievement])
}
