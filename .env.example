# Local Docker development values. Never use these credentials in production.
POSTGRES_DB=escalera
POSTGRES_USER=escalera
POSTGRES_PASSWORD=change-me-for-local-development

MINIO_ROOT_USER=escalera-local
MINIO_ROOT_PASSWORD=change-me-for-local-development
S3_BUCKET=escalera-profiles

# The server accepts this origin during local development.
CLIENT_ORIGIN=http://localhost:8080
