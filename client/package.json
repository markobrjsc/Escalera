    "socket.io-client": "^4.8.1",
    "vite": "^7.0.6",
    "vite-plugin-pwa": "^1.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6"
  }
}
